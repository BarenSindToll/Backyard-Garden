# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=<a-long-random-string>
NODE_ENV=development

# ── Brevo SMTP (transactional email) ─────────────────────────────────────────
# Sign in to https://app.brevo.com → SMTP & API → SMTP
# Click "Generate a new SMTP key" (or use an existing one).
#
# SMTP_USER  — the Brevo SMTP login shown on that page (e.g. 12ab3c456@smtp-brevo.com)
# SMTP_PASS  — the Brevo SMTP key/password shown on that page
#              This is NOT your Brevo web-login password.
#              If you have never generated one, click "Generate a new SMTP key".
#
# SENDER_EMAIL — the "From" address shown in outgoing emails.
#                Must be a verified sender in Brevo (Settings → Senders & IP).

SMTP_USER=<brevo-smtp-login@smtp-brevo.com>
SMTP_PASS=<brevo-smtp-key>
SENDER_EMAIL=<your-verified-sender@example.com>

# ── Weather API (Visual Crossing) ─────────────────────────────────────────────
# https://www.visualcrossing.com/weather-api
VITE_WEATHER_API=<visual-crossing-api-key>
OPEN_WEATHER_API=<openweathermap-api-key>

# ── Anthropic (AI garden generation) ─────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=<your-anthropic-api-key>
